      "name": "Events",
      "item": [
        {
          "name": "Create Event",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201', function () { pm.response.to.have.status(201); });",
                  "const jsonData = pm.response.json();",
                  "if (jsonData.data && jsonData.data.id) {",
                  "  pm.collectionVariables.set('event_id', jsonData.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Backend Challenge Event\",\n  \"description\": \"Test event booking system\",\n  \"capacity\": 2,\n  \"event_date\": \"2026-08-01T12:00:00Z\"\n}",
              "options": {
                "raw": {
                  "language": "json"
