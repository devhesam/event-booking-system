              }
            },
            "url": {
              "raw": "{{base_url}}/api/events/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "events",
                ""
              ]
            },
            "description": "Create event and save data.id into event_id collection variable."
          },
          "response": []
        },
        {
          "name": "Get Event Detail",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response has capacity fields', function () {",
                  "  const jsonData = pm.response.json();",
                  "  pm.expect(jsonData.data).to.have.property('capacity');",
                  "  pm.expect(jsonData.data).to.have.property('active_bookings_count');",
                  "  pm.expect(jsonData.data).to.have.property('confirmed_bookings_count');",
                  "  pm.expect(jsonData.data).to.have.property('remaining_capacity');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/events/{{event_id}}/",
              "host": [
                "{{base_url}}"
